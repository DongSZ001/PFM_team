# PF Assistant — start-time environment variables.
# Copy this file to start.env and fill in real values.
# start.env is gitignored (it contains SMTP credentials).

# ---- SMTP (QQ Mailbox recommended) ----
# QQ Mailbox SMTP authorization code (NOT QQ password).
# Generate one at: https://service.mail.qq.com/detail/0/75
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true

# Single sender mailbox (QQ mailbox).
SMTP_USER=1552403457@qq.com
SMTP_PASS=

# From address — usually same as SMTP_USER.
SMTP_FROM=1552403457@qq.com

# ---- Admin notification recipients (comma-separated) ----
ADMIN_NOTIFY_EMAIL=1552403457@qq.com,784240290@qq.com,18835389791@163.com,654083218@qq.com

# ---- Public site origin (where the app is served) ----
PUBLIC_ORIGIN=http://47.93.53.231:3000/app

# ---- OpenClaw Gateway auth ----
# Paste the gateway token from OpenClaw Control UI.
# OC_DEVICE_TOKEN is still supported for older deployments, but OC_GATEWAY_TOKEN is preferred.
OC_GATEWAY_TOKEN=
OC_GATEWAY_PASSWORD=

# NOTE: Do NOT set NODE_ENV=production while serving over plain HTTP —
# Secure cookies will not be saved by the browser and login will break.
